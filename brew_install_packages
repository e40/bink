    gawk

#####TODO:
    # not sure these are needed
    libev
    openjdk

##### can probably remove:
    wakeonlan

    # USB thumb driver creator
    #balenaetcher

    # requires the emacs-plus tap below
    #emacs-plus-app
)

taps=(
    #"emacs-plus:d12frosted/emacs-plus"
)

pipx_packages=()

if [[ $host =~ ^(max|mini18|mini24) ]]; then
    packages+=(
        yt-dlp
    )
fi

if [[ $host =~ ^(max) ]]; then

    packages+=(
        # This still works!
