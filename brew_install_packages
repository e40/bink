#if [[ $host =~ (max|mini18) ]]; then
#    # ffmpeg with improved AAC codec
#    packages_with_options+=("homebrew-ffmpeg/ffmpeg/ffmpeg --with-fdk-aac")
#fi

###############################################################################

orphans=
clean=
list=
dryrun=
oob=

while [ $# -gt 0 ]; do
    case $1 in
        --help)    usage ;;
        --orphans) orphans=$1 ;;
        --clean)   clean=$1 ;;
        --list)    list=$1 ;;
        --dry-run) dryrun=$1 ;;
        --oob)     oob=$1 ;;
        *)         break ;;
    esac
    shift
done

function member {
    local item=$1
    shift

    while test $# -gt 0; do
	if [ "$item" = "$1" ]; then
	    return 0
	fi
	shift
    done

    return 1
}

if [ "$list" ]; then
    for p in "${packages[@]}"; do echo $p; done
    for p in "${packages_with_options[@]}"; do echo $p; done
    exit 0
elif [ "$orphans" ]; then
    for leaf in $(brew leaves --installed-as-dependency); do
        if ! member "$leaf" "${packages[@]}"; then
            echo "$leaf"
        fi
    done
    exit 0
elif [ "$oob" ]; then
    # print things not in "${packages[@]}" but that
    # `brew list --installed-on-request` prints
    depends=( ${(f)"$(brew list --installed-as-dependency)"} )
    for p in $(brew list --installed-on-request); do
        if ! member "$p" "${packages[@]}"; then
            if ! member "$p" "${depends[@]}"; then
                echo "installed outside of script: $p"
            fi
        fi
    done
    exit 0
fi

{
    d "${manager[@]}" analytics off
    d "${manager[@]}" update

    if [ "${#taps[@]}" -gt 0 ]; then
        for tap in "${taps[@]}"; do
            if [[ $tap =~ ^(.*):(.*)$ ]]; then
                name="${match[1]}"
                path="${match[2]}"
            else
                errordie "Could not parse tap: $tap"
            fi
            if ! d "${manager[@]}" list "$name"; then
                echo "Tapping $name..."
                d "${manager[@]}" tap "$path"
                d "${manager[@]}" install $dryrun "$name"
            else
                echo "Tap $name already installed."
            fi
        done
    fi

    d "${manager[@]}" upgrade $dryrun

    d "${manager[@]}" install $dryrun "${packages[@]}"
    for package_with_options in "${packages_with_options[@]}"; do
        d "${manager[@]}" install $dryrun $package_with_options
    done

    [ "${#pipx_packages[@]}" -gt 0 ] &&
        d pipx install $dryrun "${pipx_packages[@]}"

    [ "$clean" ] && d "${manager[@]}" cleanup
    exit 0
}
