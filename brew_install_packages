    findutils gcc git gnu-getopt gnu-sed gnu-tar grep jq ijq lsof moreutils
    ncdu openssh p7zip lzip perl python rsync shellcheck smartmontools
    sqlite telnet wget xmlstarlet zlib the-unarchiver gnu-units
    pkgconf openssl@3

    # Use native rclone from https://rclone.org/downloads/, it has more
    # features.
#   rclone

