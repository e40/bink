#! /usr/bin/env zsh
# Use zsh because the native BASH on macOS is too old to
# run this script.

set -eu
set -o pipefail

### this was needed on macdev?
export PATH=/usr/local/bin:$PATH

prog="$(basename "$0")"

function usage {
    [ "${*-}" ] && echo "$prog: $*" 1>&2
    cat 1>&2 <<EOF
Usage: $prog [--clean]
Usage: $prog --list
Usage: $prog --dry-run
Usage: $prog --orphans
Usage: $prog --oob

Install Homebrew packages.

--list is used to list the would-be-installed packages.

--dry-run is used to see what would actually be installed, given
the already-installed packages on the current system.

--orphans is used to find packages installed for a dependency but their
original package was removed.

--oob is used to see what packages were installed outside of this script,
so they might be added to it.

Options:
--clean   :: clean up after installation

Consider using these commands to gain more insight into installed packages:

  \$ brew deps --tree --installed

  \$ brew uses --installed protobuf

EOF
    exit 1
}

function errordie {
    [ "${*-}" ] && echo "$prog: $*" 1>&2
    exit 1
}

brew=$(whence -p brew) > /dev/null || errordie Homebrew is not installed

function d {
    echo "+ $*"
    "$@"
}

packages_with_options=()

host=$(hostname -s)

if id -Gn "$USER" | grep -q -w admin; then
    manager=($brew)
elif [ -f "$HOME/.ssh/id_rsa_nopw" ]; then
    manager=(ssh -i $HOME/.ssh/id_rsa_nopw admin@$host ${brew})
else # assume SSH works to admin@...
    manager=(ssh admin@$host ${brew})
fi

# You can see what you have installed via these commands:
#   brew leaves --installed-on-request
#   brew ls --casks

packages=(
    # needed by mount_smb, which I don't really use anymore
    #autossh

